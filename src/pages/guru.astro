---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const guru = (await getCollection('guru')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Direktori Guru & Staf" description="Direktori tenaga pendidik dan kependidikan SDN Bulukerto 01.">
  <PageHeader eyebrow="Tenaga Pendidik" title="Direktori Guru & Staf" subtitle="Nama, jabatan, dan bidang tugas para pendidik dan tenaga kependidikan sekolah." />

  <section class="bg-white">
    <div class="container-x py-14 md:py-20">
      {
        guru.length > 0 ? (
          <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
            {guru.map((g) => (
              <article class="overflow-hidden rounded-lg border border-line bg-white">
                <div class="aspect-[3/4] w-full overflow-hidden bg-gray-100">
                  {g.data.photo ? (
                    <img src={g.data.photo} alt={g.data.name} width="300" height="400" class="h-full w-full object-cover" />
                  ) : (
                    <div class="flex h-full w-full flex-col items-center justify-center gap-2 text-gray-500">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 016-6h4a6 6 0 016 6v1"/></svg>
                      <span class="text-[11px] font-medium">Foto guru</span>
                    </div>
                  )}
                </div>
                <div class="border-t border-line p-4">
                  <h3 class="text-sm font-bold leading-snug text-navy">{g.data.name}</h3>
                  <p class="mt-1 text-[11px] font-semibold text-brand-700">{g.data.role}</p>
                  {g.data.nip && <p class="mt-2 text-[10px] text-ink/70">{g.data.nip}</p>}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="text-ink">Belum ada data guru.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
