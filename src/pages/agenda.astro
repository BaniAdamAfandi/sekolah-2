---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { eventDayParts, isUpcoming } from '../lib/utils';

const all = (await getCollection('agenda')).sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime());
const upcoming = all.filter((e) => isUpcoming(e.data.eventDate));
const past = all.filter((e) => !isUpcoming(e.data.eventDate)).reverse();
---

<BaseLayout title="Agenda & Kalender Akademik" description="Jadwal kegiatan dan agenda akademik SDN Bulukerto 01.">
  <PageHeader eyebrow="Kalender Akademik" title="Agenda & Event" subtitle="Daftar kegiatan mendatang beserta tanggal, lokasi, dan rincian acara." />

  <section class="bg-white">
    <div class="container-x py-14 md:py-20">
      <h2 class="text-2xl font-bold md:text-3xl">Agenda Mendatang</h2>
      {
        upcoming.length > 0 ? (
          <div class="mt-8 divide-y divide-line border-y border-line">
            {upcoming.map((e) => {
              const d = eventDayParts(e.data.eventDate);
              return (
                <div class="grid grid-cols-1 gap-4 py-6 sm:grid-cols-12 sm:items-center">
                  <div class="sm:col-span-2">
                    <div class="flex items-baseline gap-2 sm:flex-col sm:gap-0">
                      <span class="font-display text-4xl font-bold text-primary">{d.day}</span>
                      <span class="font-mono text-sm font-bold text-accent">{d.month} {d.year}</span>
                    </div>
                  </div>
                  <div class="sm:col-span-10 sm:border-l sm:border-line sm:pl-6">
                    <h3 class="text-xl font-bold text-primary">{e.data.title}</h3>
                    {e.data.location && <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink/60">📍 {e.data.location}</p>}
                    {e.data.description && <p class="mt-2 leading-relaxed text-ink">{e.data.description}</p>}
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="mt-6 text-ink">Belum ada agenda mendatang.</p>
        )
      }

      {
        past.length > 0 && (
          <div class="mt-16">
            <h2 class="text-2xl font-bold text-ink/70 md:text-3xl">Agenda Terlaksana</h2>
            <div class="mt-8 divide-y divide-line border-y border-line opacity-70">
              {past.map((e) => {
                const d = eventDayParts(e.data.eventDate);
                return (
                  <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 py-4">
                    <span class="font-mono text-sm text-accent">{d.day} {d.month} {d.year}</span>
                    <span class="text-lg font-bold text-primary">{e.data.title}</span>
                    {e.data.location && <span class="font-mono text-xs uppercase tracking-wider text-ink/50">· {e.data.location}</span>}
                  </div>
                );
              })}
            </div>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
