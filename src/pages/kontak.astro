---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getSettings } from '../lib/content';
import { waLink } from '../lib/utils';

const settings = await getSettings();
const waHref = waLink(settings.whatsapp, `Halo Admin ${settings.schoolName}, saya ingin bertanya.`);
---

<BaseLayout title="Kontak & Lokasi" description="Alamat, kontak, dan lokasi SDN Bulukerto 01 di Kota Batu.">
  <PageHeader eyebrow="Hubungi Kami" title="Kontak & Lokasi" subtitle="Silakan hubungi kami melalui kanal berikut atau kunjungi sekolah secara langsung." />

  <section class="bg-white">
    <div class="container-x grid grid-cols-1 gap-0 border border-line md:grid-cols-2">
      <!-- Info -->
      <div class="p-8 md:p-12">
        <span class="eyebrow">Informasi</span>
        <h2 class="mt-3 text-2xl font-bold md:text-3xl">Detail Kontak</h2>
        <dl class="mt-8 divide-y divide-line border-y border-line">
          <div class="py-4">
            <dt class="font-sans text-xs font-bold uppercase tracking-wider text-brand-700">Alamat</dt>
            <dd class="mt-1 leading-relaxed text-ink">{settings.address}</dd>
          </div>
          <div class="py-4">
            <dt class="font-sans text-xs font-bold uppercase tracking-wider text-brand-700">Telepon</dt>
            <dd class="mt-1 text-ink">{settings.phone}</dd>
          </div>
          <div class="py-4">
            <dt class="font-sans text-xs font-bold uppercase tracking-wider text-brand-700">Email</dt>
            <dd class="mt-1 text-ink"><a href={`mailto:${settings.email}`} class="hover:text-brand-700">{settings.email}</a></dd>
          </div>
          <div class="py-4">
            <dt class="font-sans text-xs font-bold uppercase tracking-wider text-brand-700">NPSN / Akreditasi</dt>
            <dd class="mt-1 text-ink">{settings.npsn} · {settings.akreditasi}</dd>
          </div>
        </dl>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waHref} target="_blank" rel="noopener" class="btn btn-primary">Chat WhatsApp</a>
          <a href={settings.mapsUrl} target="_blank" rel="noopener" class="btn btn-ghost">Buka Google Maps</a>
        </div>
      </div>

      <!-- Map -->
      <div class="min-h-[360px] border-t border-line md:border-l md:border-t-0">
        <iframe
          src={settings.mapsEmbed}
          title="Lokasi SDN Bulukerto 01"
          class="h-full min-h-[360px] w-full"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
