---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getPage, getSettings } from '../lib/content';
import { waLink } from '../lib/utils';

const p = await getPage('ppdb');
const settings = await getSettings();
const waHref = waLink(settings.whatsapp, `Halo Panitia PPDB ${settings.schoolName}, saya ingin mendaftar / bertanya mengenai PPDB.`);
---

<BaseLayout title={p.pageTitle} description={p.pageSubtitle}>
  <PageHeader eyebrow="Penerimaan Peserta Didik Baru" title={p.pageTitle} subtitle={p.pageSubtitle} />

  <section class="border-b border-line bg-white">
    <div class="container-x py-14 md:py-20">
      <p class="max-w-3xl text-lg leading-relaxed text-ink">{p.intro}</p>
    </div>
  </section>

  <section class="border-b border-line bg-surface">
    <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-20">
      <!-- Syarat -->
      <div class="md:col-span-6">
        <span class="eyebrow">Persyaratan</span>
        <h2 class="mt-3 text-2xl font-bold md:text-3xl">Berkas Pendaftaran</h2>
        <ol class="mt-6 divide-y divide-line border-y border-line">
          {
            p.syarat?.map((s: string, i: number) => (
              <li class="flex items-baseline gap-4 py-4">
                <span class="font-mono text-sm font-bold text-accent">{String(i + 1).padStart(2, '0')}</span>
                <span class="leading-relaxed text-ink">{s}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Alur -->
      <div class="md:col-span-6">
        <span class="eyebrow">Prosedur</span>
        <h2 class="mt-3 text-2xl font-bold md:text-3xl">Alur Pendaftaran</h2>
        <ol class="mt-6 space-y-4">
          {
            p.alur?.map((a: string, i: number) => (
              <li class="flex gap-4 border border-line bg-white p-4">
                <span class="grid h-8 w-8 shrink-0 place-items-center bg-primary font-mono text-sm font-bold text-white">{i + 1}</span>
                <span class="leading-relaxed text-ink">{a}</span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Jadwal -->
  <section class="border-b border-line bg-white">
    <div class="container-x py-16 md:py-20">
      <span class="eyebrow">Timeline</span>
      <h2 class="mt-3 text-2xl font-bold md:text-3xl">Jadwal PPDB</h2>
      <div class="mt-8 grid grid-cols-1 border border-line sm:grid-cols-2 lg:grid-cols-4">
        {
          p.jadwal?.map((j: any, i: number) => (
            <div class:list={['bg-surface p-6', i !== 0 && 'border-t border-line sm:border-l lg:border-t-0', 'lg:border-l lg:first:border-l-0']}>
              <div class="font-mono text-xs text-accent">{String(i + 1).padStart(2, '0')}/</div>
              <h3 class="mt-3 text-lg font-bold text-primary">{j.tahap}</h3>
              <p class="mt-1 font-mono text-sm text-ink">{j.tanggal}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary text-white">
    <div class="container-x grid grid-cols-1 items-center gap-6 py-14 md:grid-cols-12">
      <div class="md:col-span-8">
        <h2 class="text-2xl font-bold text-white md:text-3xl">Punya Pertanyaan Seputar PPDB?</h2>
        <p class="mt-3 max-w-2xl text-slate-400">{p.catatan}</p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a href={waHref} target="_blank" rel="noopener" class="btn btn-primary">Hubungi Panitia PPDB</a>
      </div>
    </div>
  </section>
</BaseLayout>
