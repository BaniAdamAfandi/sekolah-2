---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Halaman Tidak Ditemukan">
  <section class="bg-white">
    <div class="container-x flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
      <span class="font-display text-7xl font-bold text-accent md:text-9xl">404</span>
      <h1 class="mt-4 text-2xl font-bold md:text-3xl">Halaman Tidak Ditemukan</h1>
      <p class="mt-3 max-w-md text-ink">Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.</p>
      <a href="/" class="btn btn-primary mt-8">Kembali ke Beranda</a>
    </div>
  </section>
</BaseLayout>
