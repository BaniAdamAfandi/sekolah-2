---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import { getPage, getSettings } from '../lib/content';
import { eventDayParts, isUpcoming, waLink } from '../lib/utils';

const home = await getPage('home');
const settings = await getSettings();

const berita = (await getCollection('berita'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const agenda = (await getCollection('agenda'))
  .filter((e) => isUpcoming(e.data.eventDate))
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())
  .slice(0, 4);

const guru = (await getCollection('guru')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const galeri = (await getCollection('galeri')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const waHref = waLink(settings.whatsapp, `Halo Admin ${settings.schoolName}, saya ingin bertanya seputar PPDB.`);

const icons: Record<string, string> = {
  profil: '<path d="M12 12a4 4 0 100-8 4 4 0 000 8z"/><path d="M6 21v-1a4 4 0 014-4h4a4 4 0 014 4v1"/>',
  ppdb: '<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M21 8v6"/><path d="M6 10.5V15c0 1.5 3 3 6 3s6-1.5 6-3v-4.5"/>',
  berita: '<path d="M4 5h11v14H6a2 2 0 01-2-2V5z"/><path d="M15 8h3a2 2 0 012 2v7a2 2 0 01-2 2"/><path d="M7 9h5M7 13h5"/>',
  galeri: '<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="1.5"/><path d="M21 16l-5-5-6 6"/>',
};
---

<BaseLayout>
  <!-- ===== HERO (dua kolom) ===== -->
  <section class="border-b border-line bg-white">
    <div class="container-x grid grid-cols-1 items-center gap-10 py-14 md:py-20 lg:grid-cols-2">
      <div>
        <span class="inline-block rounded bg-brand-50 px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-700">
          {home.heroEyebrow}
        </span>
        <h1 class="mt-5 text-4xl font-bold leading-[1.15] text-navy md:text-5xl">{home.heroTitle}</h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink">{home.heroDescription}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={home.primaryButtonUrl} class="btn btn-primary">{home.primaryButtonLabel}</a>
          <a href={home.secondaryButtonUrl} class="btn btn-ghost">{home.secondaryButtonLabel}</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-lg border border-line">
        <img src={home.heroBg} alt={home.heroImageAlt} class="aspect-[4/3] w-full object-cover" />
      </div>
    </div>
  </section>

  <!-- ===== QUICK ACCESS ===== -->
  {
    home.features?.length > 0 && (
      <section class="border-b border-line bg-surface">
        <div class="container-x py-12">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {home.features.map((f: any) => (
              <a href={f.url} class="card group flex flex-col p-6 hover:shadow-card-hover">
                <span class="grid h-11 w-11 place-items-center rounded-md bg-brand-50 text-brand-700">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[f.icon] ?? icons.profil} />
                </span>
                <h3 class="mt-4 text-base font-bold text-navy group-hover:text-brand-700">{f.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-ink">{f.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== TENTANG ===== -->
  <section class="border-b border-line bg-white">
    <div class="container-x grid grid-cols-1 items-center gap-12 py-14 md:py-20 lg:grid-cols-2">
      <div class="overflow-hidden rounded-lg border border-line">
        <img src={home.heroImage} alt={home.heroImageAlt} class="aspect-[4/3] w-full object-cover" />
      </div>
      <div>
        <span class="eyebrow">Tentang Kami</span>
        <h2 class="mt-2 text-3xl font-bold leading-tight text-navy md:text-4xl">{home.aboutTitle}</h2>
        <p class="mt-4 text-lg leading-relaxed text-ink">{home.aboutText}</p>
        <ul class="mt-6 space-y-3">
          {
            home.aboutHighlights?.map((h: string) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 text-brand-600">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
                <span class="text-navy">{h}</span>
              </li>
            ))
          }
        </ul>
        <a href="/profil" class="btn btn-primary mt-8">Selengkapnya Tentang Kami</a>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="border-b border-line bg-brand-700">
    <div class="container-x grid grid-cols-2 gap-6 py-12 md:grid-cols-4">
      {
        home.stats?.map((s: any) => (
          <div class="text-center">
            <div class="text-4xl font-bold text-white md:text-5xl">{s.value}</div>
            <div class="mt-1.5 text-sm text-brand-100">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== BERITA ===== -->
  {
    home.showBerita && berita.length > 0 && (
      <section class="border-b border-line bg-white">
        <div class="container-x py-14 md:py-20">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Publikasi</span>
              <h2 class="mt-2 text-3xl font-bold text-navy md:text-4xl">Berita Terbaru</h2>
            </div>
            <a href="/berita" class="btn btn-ghost">Semua Berita</a>
          </div>
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {berita.map((b) => (
              <NewsCard
                href={`/berita/${b.slug}`}
                title={b.data.title}
                category={b.data.category}
                date={b.data.publishDate}
                excerpt={b.data.excerpt}
                thumbnail={b.data.thumbnail}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== AGENDA ===== -->
  {
    home.showAgenda && agenda.length > 0 && (
      <section class="border-b border-line bg-surface">
        <div class="container-x py-14 md:py-20">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Kalender Akademik</span>
              <h2 class="mt-2 text-3xl font-bold text-navy md:text-4xl">Agenda Mendatang</h2>
            </div>
            <a href="/agenda" class="btn btn-ghost">Semua Agenda</a>
          </div>
          <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {agenda.map((e) => {
              const d = eventDayParts(e.data.eventDate);
              return (
                <div class="card flex flex-col p-5">
                  <div class="flex items-center gap-3">
                    <div class="grid h-14 w-14 shrink-0 place-items-center rounded-md bg-brand-50 text-center text-brand-700">
                      <div>
                        <div class="text-xl font-bold leading-none">{d.day}</div>
                        <div class="mt-0.5 text-[11px] font-bold">{d.month}</div>
                      </div>
                    </div>
                    <div class="text-xs font-medium text-ink/50">{d.year}</div>
                  </div>
                  <h3 class="mt-3 text-base font-bold leading-snug text-navy">{e.data.title}</h3>
                  {e.data.location && <p class="mt-2 text-xs text-ink/70">{e.data.location}</p>}
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== GURU ===== -->
  {
    home.showGuru && guru.length > 0 && (
      <section class="border-b border-line bg-white">
        <div class="container-x py-14 md:py-20">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Tenaga Pendidik</span>
              <h2 class="mt-2 text-3xl font-bold text-navy md:text-4xl">Guru & Staf</h2>
            </div>
            <a href="/guru" class="btn btn-ghost">Direktori Lengkap</a>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-4">
            {guru.map((g) => (
              <article class="card overflow-hidden text-center">
                <div class="aspect-[3/4] w-full overflow-hidden bg-gray-100">
                  {g.data.photo ? (
                    <img src={g.data.photo} alt={g.data.name} class="h-full w-full object-cover" />
                  ) : (
                    <div class="flex h-full w-full flex-col items-center justify-center gap-2 text-gray-400">
                      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 016-6h4a6 6 0 016 6v1"/></svg>
                      <span class="text-[11px] font-medium">Foto guru</span>
                    </div>
                  )}
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-bold leading-snug text-navy">{g.data.name}</h3>
                  <p class="mt-1 text-xs font-semibold text-brand-700">{g.data.role}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== GALERI ===== -->
  {
    home.showGaleri && galeri.length > 0 && (
      <section class="border-b border-line bg-surface">
        <div class="container-x py-14 md:py-20">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Dokumentasi</span>
              <h2 class="mt-2 text-3xl font-bold text-navy md:text-4xl">Fasilitas & Galeri</h2>
            </div>
            <a href="/galeri" class="btn btn-ghost">Semua Foto</a>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-4">
            {galeri.map((g) => (
              <figure class="overflow-hidden rounded-lg border border-line">
                <img src={g.data.image} alt={g.data.title} class="aspect-square w-full object-cover" />
                <figcaption class="border-t border-line bg-white px-3 py-2 text-sm font-medium text-navy">{g.data.title}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== CTA ===== -->
  <section class="bg-navy">
    <div class="container-x grid grid-cols-1 items-center gap-8 py-14 md:grid-cols-12 md:py-16">
      <div class="md:col-span-8">
        <h2 class="text-2xl font-bold leading-tight text-white md:text-3xl">{home.ctaTitle}</h2>
        <p class="mt-3 max-w-2xl text-slate-300">{home.ctaText}</p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a href={waHref} target="_blank" rel="noopener" class="btn btn-amber">{home.ctaButtonLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
