---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPage, getSettings } from '../lib/content';
import { eventDayParts, formatDate, isUpcoming, waLink } from '../lib/utils';

const home = await getPage('home');
const profil = await getPage('profil');
const settings = await getSettings();

const beritaAll = (await getCollection('berita')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const beritaUtama = beritaAll[0];
const beritaLain = beritaAll.slice(1, 4);

const agenda = (await getCollection('agenda'))
  .filter((e) => isUpcoming(e.data.eventDate))
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())
  .slice(0, 3);

const galeri = (await getCollection('galeri')).sort((a, b) => a.data.order - b.data.order).slice(0, 6);

const waHref = waLink(settings.whatsapp, `Halo Admin ${settings.schoolName}, saya ingin bertanya seputar PPDB.`);
const akredShort = (settings.akreditasi ?? 'A').split(' ')[0];
const greeting = (profil.sambutanText ?? '').slice(0, 420) + ((profil.sambutanText ?? '').length > 420 ? '…' : '');
const heroFotos = [galeri[0]?.data.image, home.heroImage, galeri[1]?.data.image].filter(Boolean);
---

<BaseLayout>
  <!-- ===================== HERO (rata tengah + kolase foto) ===================== -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-brand-50 via-surface to-surface"></div>
    <div class="animate-float absolute -left-24 top-10 -z-10 h-72 w-72 rounded-full bg-brand-200/40 blur-3xl"></div>
    <div class="animate-float-slow absolute -right-24 top-32 -z-10 h-72 w-72 rounded-full bg-accent-100/60 blur-3xl"></div>

    <div class="container-x pt-14 text-center lg:pt-20">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-1.5 text-sm font-bold text-brand-700 shadow-soft ring-1 ring-brand-100">
        🏫 Selamat Datang di {settings.schoolName}
      </span>
      <h1 class="mx-auto mt-5 max-w-3xl font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
        {home.heroTitle}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-stone-600">{home.heroDescription}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={home.primaryButtonUrl} class="btn btn-primary px-7 py-3.5 text-base">{home.primaryButtonLabel}</a>
        <a href={home.secondaryButtonUrl} class="btn btn-accent px-7 py-3.5 text-base">{home.secondaryButtonLabel}</a>
      </div>

      <!-- Kolase tiga foto -->
      <div class="relative mx-auto mt-12 flex max-w-4xl items-end justify-center gap-4 sm:gap-6">
        <div class="hidden w-1/4 -rotate-3 overflow-hidden rounded-t-full rounded-b-3xl ring-4 ring-white shadow-xl sm:block">
          <div class="relative aspect-[3/4] bg-gradient-to-br from-brand-100 to-accent-100">
            {heroFotos[0] && <img src={heroFotos[0]} alt="Kegiatan sekolah" class="absolute inset-0 h-full w-full object-cover" loading="eager" decoding="async" />}
          </div>
        </div>
        <div class="relative w-full max-w-md overflow-hidden rounded-t-[3rem] rounded-b-3xl ring-8 ring-white shadow-2xl shadow-brand-900/15 sm:w-1/2">
          <div class="relative aspect-[4/3] bg-gradient-to-br from-brand-100 via-surface to-accent-100">
            <img src={heroFotos[1] ?? home.heroImage} alt={home.heroImageAlt} class="absolute inset-0 h-full w-full object-cover" loading="eager" decoding="async" />
          </div>
          <span class="animate-float absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1.5 text-xs font-bold text-brand-700 shadow-sm backdrop-blur">
            {settings.studentCount} Siswa Aktif
          </span>
          <span class="animate-float-slow absolute right-3 top-3 rounded-full bg-accent px-3 py-1.5 text-xs font-bold text-white shadow-sm">
            Akreditasi {akredShort}
          </span>
        </div>
        <div class="hidden w-1/4 rotate-3 overflow-hidden rounded-t-full rounded-b-3xl ring-4 ring-white shadow-xl sm:block">
          <div class="relative aspect-[3/4] bg-gradient-to-br from-accent-100 to-brand-100">
            {heroFotos[2] && <img src={heroFotos[2]} alt="Kegiatan siswa" class="absolute inset-0 h-full w-full object-cover" loading="eager" decoding="async" />}
          </div>
        </div>
      </div>
    </div>

    <!-- Pita statistik bergelombang -->
    <div class="-mt-10">
      <svg class="block h-12 w-full text-brand-600 sm:h-14" viewBox="0 0 1440 60" fill="currentColor" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,40 C240,80 480,0 720,20 C960,40 1200,70 1440,30 L1440,60 L0,60 Z"></path>
      </svg>
      <div class="bg-brand-600 pb-10 pt-6 text-white sm:pt-4">
        <div class="container-x grid grid-cols-2 gap-x-4 gap-y-6 text-center md:grid-cols-4">
          {
            home.stats?.map((s: any) => (
              <div>
                <p class="font-display text-3xl font-bold sm:text-4xl">{s.value}</p>
                <p class="mt-0.5 text-sm text-brand-100">{s.label}</p>
              </div>
            ))
          }
        </div>
      </div>
      <svg class="block h-12 w-full rotate-180 text-brand-600 sm:h-14" viewBox="0 0 1440 60" fill="currentColor" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,40 C240,80 480,0 720,20 C960,40 1200,70 1440,30 L1440,60 L0,60 Z"></path>
      </svg>
    </div>
  </section>

  <!-- ===================== SAMBUTAN (foto lengkung) ===================== -->
  <section class="container-x py-12" data-reveal>
    <div class="grid items-center gap-10 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <div class="relative mx-auto max-w-[260px]">
          <div class="absolute -bottom-3 -right-3 h-full w-full rounded-t-full rounded-b-[2rem] bg-accent-100"></div>
          <div class="relative overflow-hidden rounded-t-full rounded-b-[2rem] ring-4 ring-white shadow-xl">
            <div class="relative aspect-[3/4] bg-gradient-to-br from-brand-100 via-surface to-accent-100">
              <img src={profil.sambutanFoto} alt={profil.sambutanNama} class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />
            </div>
          </div>
        </div>
      </div>
      <div class="text-center lg:col-span-3 lg:text-left">
        <span class="eyebrow">Sambutan Kepala Sekolah</span>
        <h2 class="mt-2 font-display text-2xl font-bold text-ink sm:text-3xl">Salam Hangat dari {settings.schoolName}</h2>
        <p class="mt-4 leading-relaxed text-stone-600">{greeting}</p>
        <p class="mt-4 font-display text-lg font-bold text-brand-700">{profil.sambutanNama}</p>
        <p class="text-sm text-stone-500">{profil.sambutanJabatan}</p>
        <a href="/profil" class="btn btn-ghost mt-6">Profil Lengkap Sekolah</a>
      </div>
    </div>
  </section>

  <!-- ===================== BERITA (1 utama + daftar) ===================== -->
  {
    home.showBerita && beritaUtama && (
      <section class="bg-white py-14" data-reveal>
        <div class="container-x">
          <div class="text-center">
            <span class="eyebrow">Kabar Sekolah</span>
            <h2 class="mt-1 font-display text-2xl font-bold text-ink sm:text-3xl">Berita & Kegiatan Terbaru</h2>
          </div>
          <div class="mt-10 grid gap-8 lg:grid-cols-2">
            <!-- Berita utama -->
            <a href={`/berita/${beritaUtama.slug}`} class="card card-lift group overflow-hidden">
              <div class="relative aspect-video bg-gradient-to-br from-brand-100 via-surface to-accent-100">
                {beritaUtama.data.thumbnail ? (
                  <img src={beritaUtama.data.thumbnail} alt={beritaUtama.data.title} class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center text-brand-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" /></svg>
                  </div>
                )}
                <span class="badge absolute left-4 top-4">{beritaUtama.data.category}</span>
              </div>
              <div class="p-6">
                <time class="text-xs font-semibold text-stone-400">{formatDate(beritaUtama.data.publishDate)}</time>
                <h3 class="mt-2 font-display text-xl font-bold leading-snug text-ink transition-colors group-hover:text-brand-700 sm:text-2xl">
                  {beritaUtama.data.title}
                </h3>
                {beritaUtama.data.excerpt && <p class="mt-2 line-clamp-3 leading-relaxed text-stone-600">{beritaUtama.data.excerpt}</p>}
              </div>
            </a>

            <!-- Daftar berita ringkas -->
            <div class="flex flex-col gap-4">
              {beritaLain.map((b) => (
                <a href={`/berita/${b.slug}`} class="card card-lift group flex gap-4 p-4">
                  <div class="relative h-24 w-32 shrink-0 overflow-hidden rounded-xl bg-gradient-to-br from-brand-100 to-accent-100">
                    {b.data.thumbnail && <img src={b.data.thumbnail} alt={b.data.title} class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />}
                  </div>
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2 text-xs">
                      <span class="font-bold uppercase tracking-wide text-accent">{b.data.category}</span>
                      <span class="text-stone-400">{formatDate(b.data.publishDate)}</span>
                    </div>
                    <h3 class="mt-1.5 font-display text-base font-bold leading-snug text-ink transition-colors group-hover:text-brand-700">
                      {b.data.title}
                    </h3>
                  </div>
                </a>
              ))}
              <a href="/berita" class="btn btn-ghost self-start">Lihat Semua Berita</a>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===================== AGENDA (daftar terang) ===================== -->
  {
    home.showAgenda && agenda.length > 0 && (
      <section class="container-x py-14" data-reveal>
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <span class="eyebrow">Jangan Terlewat</span>
            <h2 class="mt-1 font-display text-2xl font-bold text-ink sm:text-3xl">Agenda Sekolah</h2>
          </div>
          <a href="/agenda" class="btn btn-ghost">Semua Agenda</a>
        </div>
        <div class="mt-8 space-y-4">
          {agenda.map((e) => {
            const d = eventDayParts(e.data.eventDate);
            return (
              <div class="card flex items-center gap-5 p-5 sm:p-6">
                <div class="flex h-16 w-16 shrink-0 flex-col items-center justify-center rounded-full bg-accent-50 text-accent-dark ring-2 ring-accent-100">
                  <span class="font-display text-xl font-bold leading-none">{d.day}</span>
                  <span class="text-[11px] font-bold uppercase">{d.month}</span>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="font-display text-lg font-bold leading-snug text-ink">{e.data.title}</h3>
                  <div class="mt-1 flex flex-wrap gap-x-4 gap-y-0.5 text-sm text-stone-500">
                    {e.data.location && <span>📍 {e.data.location}</span>}
                    <span>🗓️ {d.day} {d.month} {d.year}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- ===================== GALERI STRIP ===================== -->
  {
    home.showGaleri && galeri.length > 0 && (
      <section class="overflow-hidden py-6" data-reveal>
        <div class="container-x text-center">
          <span class="eyebrow">Galeri</span>
          <h2 class="mt-1 font-display text-2xl font-bold text-ink sm:text-3xl">Keceriaan di Sekolah Kami</h2>
        </div>
        <div class="mt-8 flex gap-4 overflow-x-auto px-4 pb-4 sm:px-8 [scrollbar-width:thin]">
          {galeri.map((g, i) => (
            <a href="/galeri" class:list={['block w-56 shrink-0 overflow-hidden shadow-md ring-4 ring-white', i % 2 === 0 ? 'rounded-t-[2.5rem] rounded-b-2xl' : 'rounded-b-[2.5rem] rounded-t-2xl']}>
              <img src={g.data.image} alt={g.data.title} class="aspect-square w-full object-cover" loading="lazy" decoding="async" />
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- ===================== CTA PPDB ===================== -->
  <section class="container-x py-12" data-reveal>
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-brand-500 to-brand-600 p-8 text-white sm:p-12">
      <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-white/10"></div>
      <div class="absolute -bottom-16 right-24 h-40 w-40 rounded-full bg-accent/25"></div>
      <div class="relative grid items-center gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">{home.ctaTitle}</h2>
          <p class="mt-3 max-w-xl text-brand-50">{home.ctaText}</p>
        </div>
        <div class="flex flex-wrap gap-3 lg:justify-end">
          <a href="/ppdb" class="inline-block rounded-full bg-white px-7 py-3.5 text-base font-bold text-brand-600 shadow-lg transition-transform hover:-translate-y-0.5">
            Info PPDB
          </a>
          <a href={waHref} target="_blank" rel="noopener" class="inline-block rounded-full bg-accent px-7 py-3.5 text-base font-bold text-white shadow-lg transition-transform hover:-translate-y-0.5 hover:bg-accent-dark">
            WhatsApp Kami
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
