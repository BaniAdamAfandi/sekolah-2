---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsRow from '../components/NewsRow.astro';
import { getPage, getSettings } from '../lib/content';
import { eventDayParts, isUpcoming, waLink } from '../lib/utils';

const home = await getPage('home');
const settings = await getSettings();

const berita = (await getCollection('berita'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const agenda = (await getCollection('agenda'))
  .filter((e) => isUpcoming(e.data.eventDate))
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())
  .slice(0, 3);

const guru = (await getCollection('guru')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const galeri = (await getCollection('galeri')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const waHref = waLink(settings.whatsapp, `Halo Admin ${settings.schoolName}, saya ingin bertanya seputar PPDB.`);
---

<BaseLayout>
  <!-- ===== HERO (asymmetric 7 / 5) ===== -->
  <section class="border-b border-line bg-white">
    <div class="container-x grid grid-cols-1 items-stretch gap-0 lg:grid-cols-12">
      <div class="flex flex-col justify-center py-14 lg:col-span-7 lg:py-24 lg:pr-12">
        <span class="eyebrow">{home.heroEyebrow}</span>
        <h1 class="mt-5 text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl md:text-6xl">
          {home.heroTitle}
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink">{home.heroDescription}</p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a href={home.primaryButtonUrl} class="btn btn-primary">{home.primaryButtonLabel}</a>
          <a href={home.secondaryButtonUrl} class="btn btn-ghost">{home.secondaryButtonLabel}</a>
        </div>
      </div>
      <div class="relative lg:col-span-5">
        <div class="h-full border-l border-line lg:pl-10 lg:pt-10">
          <div class="relative h-full min-h-[380px] p-3">
            <div class="absolute inset-0 translate-x-3 translate-y-3 border border-accent"></div>
            <img
              src={home.heroImage}
              alt={home.heroImageAlt}
              width="800"
              height="1000"
              class="relative h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="border-b border-line bg-primary text-white">
    <div class="container-x grid grid-cols-2 md:grid-cols-4">
      {
        home.stats?.map((s: any, i: number) => (
          <div class:list={['px-2 py-10 md:px-6', i !== 0 && 'md:border-l md:border-white/10', i % 2 !== 0 && 'border-l border-white/10 md:border-l']}>
            <div class="font-mono text-xs text-accent-light">{String(i + 1).padStart(2, '0')}/</div>
            <div class="mt-2 font-display text-4xl font-bold md:text-5xl">{s.value}</div>
            <div class="mt-2 text-sm text-slate-400">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="border-b border-line bg-surface">
    <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-24">
      <div class="md:col-span-5">
        <span class="eyebrow">Tentang Kami</span>
        <h2 class="mt-3 text-3xl font-bold leading-tight md:text-4xl">{home.aboutTitle}</h2>
      </div>
      <div class="md:col-span-7">
        <p class="text-lg leading-relaxed text-ink">{home.aboutText}</p>
        <ul class="mt-8 divide-y divide-line border-t border-line">
          {
            home.aboutHighlights?.map((h: string, i: number) => (
              <li class="flex items-baseline gap-4 py-4">
                <span class="font-mono text-sm text-accent">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-base text-primary">{h}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== NEWS (split screen) ===== -->
  {
    home.showBerita && (
      <section class="border-b border-line bg-white">
        <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-24">
          <div class="md:col-span-4">
            <span class="eyebrow">Publikasi</span>
            <h2 class="mt-3 text-3xl font-bold leading-tight md:text-4xl">Berita Terbaru</h2>
            <p class="mt-4 text-ink">Kabar terkini seputar kegiatan, prestasi, dan pengumuman sekolah.</p>
            <a href="/berita" class="btn btn-ghost mt-8">Semua Berita</a>
          </div>
          <div class="md:col-span-8 md:border-l md:border-line md:pl-10">
            <div class="border-t border-line">
              {berita.map((b) => (
                <NewsRow
                  href={`/berita/${b.slug}`}
                  title={b.data.title}
                  category={b.data.category}
                  date={b.data.publishDate}
                  excerpt={b.data.excerpt}
                />
              ))}
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== AGENDA ===== -->
  {
    home.showAgenda && agenda.length > 0 && (
      <section class="border-b border-line bg-surface">
        <div class="container-x py-16 md:py-24">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Kalender Akademik</span>
              <h2 class="mt-3 text-3xl font-bold leading-tight md:text-4xl">Agenda Mendatang</h2>
            </div>
            <a href="/agenda" class="btn btn-ghost">Semua Agenda</a>
          </div>
          <div class="mt-10 grid grid-cols-1 gap-0 border border-line md:grid-cols-3">
            {agenda.map((e, i) => {
              const d = eventDayParts(e.data.eventDate);
              return (
                <div class:list={['bg-white p-7', i !== 0 && 'border-t border-line md:border-l md:border-t-0']}>
                  <div class="flex items-baseline gap-2 font-display text-primary">
                    <span class="text-4xl font-bold">{d.day}</span>
                    <span class="font-mono text-sm font-bold text-accent">{d.month}</span>
                    <span class="font-mono text-sm text-ink/50">{d.year}</span>
                  </div>
                  <h3 class="mt-4 text-lg font-bold leading-snug">{e.data.title}</h3>
                  {e.data.location && <p class="mt-2 font-mono text-xs uppercase tracking-wider text-ink/60">{e.data.location}</p>}
                  {e.data.description && <p class="mt-3 text-sm leading-relaxed text-ink">{e.data.description}</p>}
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== GURU ===== -->
  {
    home.showGuru && guru.length > 0 && (
      <section class="border-b border-line bg-white">
        <div class="container-x py-16 md:py-24">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Tenaga Pendidik</span>
              <h2 class="mt-3 text-3xl font-bold leading-tight md:text-4xl">Guru & Staf</h2>
            </div>
            <a href="/guru" class="btn btn-ghost">Direktori Lengkap</a>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-4">
            {guru.map((g) => (
              <article class="border border-line bg-white">
                <div class="aspect-[3/4] w-full overflow-hidden bg-primary/5">
                  {g.data.photo ? (
                    <img src={g.data.photo} alt={g.data.name} width="300" height="400" class="h-full w-full object-cover" />
                  ) : (
                    <div class="grid h-full w-full place-items-center bg-gradient-to-br from-primary to-accent">
                      <span class="font-display text-3xl font-bold text-white/90">
                        {g.data.name.split(' ').filter(Boolean).slice(0, 2).map((n) => n[0]).join('')}
                      </span>
                    </div>
                  )}
                </div>
                <div class="border-t border-line p-4">
                  <h3 class="text-sm font-bold leading-snug text-primary">{g.data.name}</h3>
                  <p class="mt-1 font-mono text-[11px] uppercase tracking-wider text-accent">{g.data.role}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== GALERI ===== -->
  {
    home.showGaleri && galeri.length > 0 && (
      <section class="border-b border-line bg-surface">
        <div class="container-x py-16 md:py-24">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow">Dokumentasi</span>
              <h2 class="mt-3 text-3xl font-bold leading-tight md:text-4xl">Fasilitas & Galeri</h2>
            </div>
            <a href="/galeri" class="btn btn-ghost">Semua Foto</a>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-4 md:grid-cols-4">
            {galeri.map((g) => (
              <figure class="group relative overflow-hidden border border-line">
                <img
                  src={g.data.image}
                  alt={g.data.title}
                  width="800"
                  height="600"
                  class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <figcaption class="absolute inset-x-0 bottom-0 bg-primary/80 px-3 py-2 font-mono text-[11px] uppercase tracking-wider text-white">
                  {g.data.title}
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== CTA ===== -->
  <section class="bg-primary text-white">
    <div class="container-x grid grid-cols-1 items-center gap-8 py-16 md:grid-cols-12 md:py-20">
      <div class="md:col-span-8">
        <h2 class="text-3xl font-bold leading-tight text-white md:text-4xl">{home.ctaTitle}</h2>
        <p class="mt-4 max-w-2xl text-slate-400">{home.ctaText}</p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a href={waHref} target="_blank" rel="noopener" class="btn btn-primary">{home.ctaButtonLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
