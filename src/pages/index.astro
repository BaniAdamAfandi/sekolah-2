---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPage, getSettings } from '../lib/content';
import { eventDayParts, formatDate, isUpcoming, waLink } from '../lib/utils';

const home = await getPage('home');
const profil = await getPage('profil');
const settings = await getSettings();

const berita = (await getCollection('berita'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 4);

const agenda = (await getCollection('agenda'))
  .filter((e) => isUpcoming(e.data.eventDate))
  .sort((a, b) => a.data.eventDate.getTime() - b.data.eventDate.getTime())
  .slice(0, 4);

const galeri = (await getCollection('galeri')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const waHref = waLink(settings.whatsapp, `Halo Admin ${settings.schoolName}, saya ingin bertanya seputar PPDB.`);
const sambutanExcerpt = (profil.sambutanText ?? '').slice(0, 320) + ((profil.sambutanText ?? '').length > 320 ? '…' : '');
---

<BaseLayout>
  <!-- Banner -->
  <section class="border-b border-line bg-white">
    <div class="container-x py-5">
      <div class="relative overflow-hidden rounded-md border border-line">
        <img src={home.heroBg} alt={home.heroImageAlt} class="h-52 w-full object-cover sm:h-64 md:h-80" />
        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-navy/80 to-transparent">
          <div class="p-5 md:p-7">
            <h1 class="text-2xl font-bold text-white md:text-3xl">Selamat Datang di {settings.schoolName}</h1>
            <p class="mt-1 max-w-2xl text-sm text-slate-200 md:text-base">{home.heroDescription}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Konten + Sidebar -->
  <section class="bg-surface">
    <div class="container-x grid grid-cols-1 gap-8 py-10 lg:grid-cols-3 lg:py-12">
      <!-- Kolom konten -->
      <div class="space-y-10 lg:col-span-2">
        <!-- Sambutan -->
        <div>
          <div class="sec-head"><h2>Sambutan Kepala Sekolah</h2></div>
          <div class="flex flex-col gap-5 sm:flex-row">
            <img src={profil.sambutanFoto} alt={profil.sambutanNama} class="h-48 w-40 shrink-0 self-start rounded-md border border-line object-cover" />
            <div>
              <p class="leading-relaxed text-ink">{sambutanExcerpt}</p>
              <p class="mt-3 font-bold text-navy">{profil.sambutanNama}</p>
              <p class="text-sm text-brand-700">{profil.sambutanJabatan}</p>
              <a href="/profil" class="mt-3 inline-block text-sm font-semibold text-brand-700 hover:underline">Selengkapnya »</a>
            </div>
          </div>
        </div>

        <!-- Berita -->
        <div>
          <div class="sec-head">
            <h2>Berita Terbaru</h2>
            <a href="/berita" class="text-sm font-semibold text-brand-700 hover:underline">Semua Berita »</a>
          </div>
          <div class="divide-y divide-line">
            {
              berita.map((b) => (
                <a href={`/berita/${b.slug}`} class="group flex gap-4 py-4">
                  <div class="h-20 w-28 shrink-0 overflow-hidden rounded border border-line bg-gray-100">
                    {b.data.thumbnail ? (
                      <img src={b.data.thumbnail} alt={b.data.title} class="h-full w-full object-cover" />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center text-gray-400">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M21 16l-5-5-8 8"/></svg>
                      </div>
                    )}
                  </div>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2 text-xs text-ink/60">
                      <span class="font-semibold uppercase text-brand-700">{b.data.category}</span>
                      <span>•</span>
                      <span>{formatDate(b.data.publishDate)}</span>
                    </div>
                    <h3 class="mt-1 font-bold leading-snug text-navy group-hover:text-brand-700">{b.data.title}</h3>
                    {b.data.excerpt && <p class="mt-1 line-clamp-2 text-sm text-ink">{b.data.excerpt}</p>}
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Data sekolah -->
        <div>
          <div class="sec-head"><h2>Data & Statistik Sekolah</h2></div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            {
              home.stats?.map((s: any) => (
                <div class="rounded-md border border-line bg-white p-4 text-center">
                  <div class="text-2xl font-bold text-brand-700">{s.value}</div>
                  <div class="mt-1 text-xs text-ink/70">{s.label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Profil sekolah -->
        <div class="widget">
          <div class="widget-head">Profil Sekolah</div>
          <div class="widget-body">
            <table class="w-full text-sm">
              <tbody class="divide-y divide-line">
                <tr><td class="py-2 text-ink/70">NPSN</td><td class="py-2 text-right font-semibold text-navy">{settings.npsn}</td></tr>
                <tr><td class="py-2 text-ink/70">Status</td><td class="py-2 text-right font-semibold text-navy">{settings.status}</td></tr>
                <tr><td class="py-2 text-ink/70">Akreditasi</td><td class="py-2 text-right font-semibold text-navy">{settings.akreditasi}</td></tr>
              </tbody>
            </table>
            <p class="mt-3 border-t border-line pt-3 text-sm leading-relaxed text-ink">{settings.address}</p>
          </div>
        </div>

        <!-- Agenda -->
        {
          agenda.length > 0 && (
            <div class="widget">
              <div class="widget-head">Agenda Kegiatan</div>
              <div class="widget-body space-y-3">
                {agenda.map((e) => {
                  const d = eventDayParts(e.data.eventDate);
                  return (
                    <div class="flex gap-3 border-b border-line pb-3 last:border-0 last:pb-0">
                      <div class="grid h-12 w-12 shrink-0 place-items-center rounded bg-brand-50 text-center text-brand-700">
                        <div>
                          <div class="text-base font-bold leading-none">{d.day}</div>
                          <div class="text-[10px] font-bold">{d.month}</div>
                        </div>
                      </div>
                      <div class="min-w-0">
                        <p class="text-sm font-semibold leading-snug text-navy">{e.data.title}</p>
                        {e.data.location && <p class="mt-0.5 text-xs text-ink/60">{e.data.location}</p>}
                      </div>
                    </div>
                  );
                })}
                <a href="/agenda" class="block text-sm font-semibold text-brand-700 hover:underline">Semua Agenda »</a>
              </div>
            </div>
          )
        }

        <!-- PPDB -->
        <div class="widget">
          <div class="widget-head">Informasi PPDB {settings.admissionsLabel?.match(/\d{4}/)?.[0] ?? ''}</div>
          <div class="widget-body">
            <p class="text-sm leading-relaxed text-ink">Penerimaan Peserta Didik Baru telah dibuka. Lihat syarat, jadwal, dan alur pendaftaran.</p>
            <div class="mt-3 flex flex-col gap-2">
              <a href="/ppdb" class="btn btn-primary w-full py-2.5 text-xs">Info Pendaftaran</a>
              <a href={waHref} target="_blank" rel="noopener" class="btn btn-ghost w-full py-2.5 text-xs">Tanya via WhatsApp</a>
            </div>
          </div>
        </div>

        <!-- Galeri -->
        {
          galeri.length > 0 && (
            <div class="widget">
              <div class="widget-head">Galeri Sekolah</div>
              <div class="widget-body">
                <div class="grid grid-cols-2 gap-2">
                  {galeri.map((g) => (
                    <a href="/galeri" class="block overflow-hidden rounded border border-line">
                      <img src={g.data.image} alt={g.data.title} class="aspect-square w-full object-cover" />
                    </a>
                  ))}
                </div>
                <a href="/galeri" class="mt-3 block text-sm font-semibold text-brand-700 hover:underline">Lihat Galeri »</a>
              </div>
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>
