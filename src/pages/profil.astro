---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getPage } from '../lib/content';

const p = await getPage('profil');
---

<BaseLayout title={p.pageTitle} description={p.pageSubtitle}>
  <PageHeader eyebrow="Tentang Sekolah" title={p.pageTitle} subtitle={p.pageSubtitle} />

  <!-- Sambutan -->
  <section class="border-b border-line bg-surface">
    <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-20">
      <div class="md:col-span-4">
        <div class="overflow-hidden rounded-lg border border-line">
          <img
            src={p.sambutanFoto}
            alt={p.sambutanNama}
            width="600"
            height="800"
            class="aspect-[3/4] w-full object-cover"
          />
        </div>
      </div>
      <div class="md:col-span-8">
        <span class="eyebrow">Sambutan</span>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Sambutan {p.sambutanJabatan}</h2>
        <p class="mt-6 whitespace-pre-line text-lg leading-relaxed text-ink">{p.sambutanText}</p>
        <div class="mt-8 border-t border-line pt-5">
          <p class="font-display text-lg font-bold text-navy">{p.sambutanNama}</p>
          <p class="font-sans text-xs uppercase tracking-wider text-brand-700">{p.sambutanJabatan}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visi Misi -->
  <section class="border-b border-line bg-white">
    <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-20">
      <div class="md:col-span-5">
        <span class="eyebrow">Arah Kebijakan</span>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Visi & Misi</h2>
        <div class="mt-8 border border-line bg-surface p-7">
          <h3 class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-brand-700">Visi</h3>
          <p class="mt-3 text-lg font-medium leading-relaxed text-navy">{p.visi}</p>
        </div>
      </div>
      <div class="md:col-span-7">
        <h3 class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-brand-700 md:mt-[4.75rem]">Misi</h3>
        <ol class="mt-4 divide-y divide-line border-t border-line">
          {
            p.misi?.map((m: string, i: number) => (
              <li class="flex items-baseline gap-4 py-4">
                <span class="font-sans text-sm font-bold text-brand-700">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-base leading-relaxed text-ink">{m}</span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Sejarah -->
  <section class="border-b border-line bg-surface">
    <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12 md:py-20">
      <div class="md:col-span-4">
        <span class="eyebrow">Rekam Jejak</span>
        <h2 class="mt-3 text-3xl font-bold md:text-4xl">Sejarah Singkat</h2>
      </div>
      <div class="md:col-span-8">
        <p class="whitespace-pre-line text-lg leading-relaxed text-ink">{p.sejarah}</p>
      </div>
    </div>
  </section>

  <!-- Komite -->
  {
    p.komite?.length > 0 && (
      <section class="bg-white">
        <div class="container-x py-16 md:py-20">
          <span class="eyebrow">Tata Kelola</span>
          <h2 class="mt-3 text-3xl font-bold md:text-4xl">Komite Sekolah</h2>
          <div class="mt-10 grid grid-cols-1 border border-line sm:grid-cols-3">
            {p.komite.map((k: any, i: number) => (
              <div class:list={['bg-surface p-7', i !== 0 && 'border-t border-line sm:border-l sm:border-t-0']}>
                <div class="font-sans text-xs text-brand-700">{String(i + 1).padStart(2, '0')}/</div>
                <p class="mt-3 font-display text-lg font-bold text-navy">{k.name}</p>
                <p class="mt-1 font-sans text-xs uppercase tracking-wider text-ink/70">{k.role}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
