---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import NewsCard from '../../components/NewsCard.astro';

const berita = (await getCollection('berita')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const categories = ['Semua', ...new Set(berita.map((b) => b.data.category))];
---

<BaseLayout title="Berita & Publikasi" description="Berita, pengumuman, dan publikasi terkini SDN Bulukerto 01.">
  <PageHeader eyebrow="Publikasi" title="Berita & Publikasi" subtitle="Kabar terkini seputar kegiatan, prestasi, dan pengumuman resmi sekolah." />

  <section class="bg-surface">
    <div class="container-x section">
      <!-- Filter (client-side) -->
      <div class="mb-10 flex flex-wrap gap-2" id="filter-bar">
        {
          categories.map((c) => (
            <button
              type="button"
              data-cat={c}
              class:list={[
                'filter-btn rounded-full px-4 py-2 text-sm font-semibold transition-colors',
                c === 'Semua' ? 'bg-brand-800 text-white' : 'bg-white text-brand-700 ring-1 ring-brand-200 hover:bg-brand-50',
              ]}
            >
              {c}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="news-list">
        {
          berita.map((b) => (
            <div class="news-item" data-cat={b.data.category}>
              <NewsCard
                href={`/berita/${b.slug}`}
                title={b.data.title}
                category={b.data.category}
                date={b.data.publishDate}
                excerpt={b.data.excerpt}
                thumbnail={b.data.thumbnail}
              />
            </div>
          ))
        }
      </div>
      {berita.length === 0 && <p class="py-10 text-center text-ink">Belum ada berita.</p>}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.news-item');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      buttons.forEach((b) => {
        b.classList.remove('bg-brand-800', 'text-white');
        b.classList.add('bg-white', 'text-brand-700', 'ring-1', 'ring-brand-200', 'hover:bg-brand-50');
      });
      btn.classList.add('bg-brand-800', 'text-white');
      btn.classList.remove('bg-white', 'text-brand-700', 'ring-1', 'ring-brand-200', 'hover:bg-brand-50');
      items.forEach((it) => {
        it.style.display = cat === 'Semua' || it.dataset.cat === cat ? '' : 'none';
      });
    });
  });
</script>
