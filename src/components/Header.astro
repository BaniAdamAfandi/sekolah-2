---
interface Props {
  settings: Record<string, any>;
}
const { settings } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { label: 'Beranda', url: '/' },
  { label: 'Profil', url: '/profil' },
  { label: 'Berita', url: '/berita' },
  { label: 'Guru', url: '/guru' },
  { label: 'Agenda', url: '/agenda' },
  { label: 'Galeri', url: '/galeri' },
  { label: 'Modul', url: '/modul' },
  { label: 'Kontak', url: '/kontak' },
];
const isActive = (url: string) => (url === '/' ? path === '/' : path.startsWith(url));
---

<header class="sticky top-0 z-50 border-b border-slate-200/60 bg-white/85 backdrop-blur-md">
  <nav class="container-x flex h-[4.5rem] items-center justify-between gap-4">
    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center gap-3">
      <img src={settings.logo} alt={`Logo ${settings.schoolName}`} width="40" height="40" class="h-10 w-10 rounded-xl object-contain" />
      <span class="flex flex-col leading-none">
        <span class="font-display text-base font-bold text-brand-800">{settings.schoolName}</span>
        <span class="text-[11px] text-slate-500">Kota Batu, Jawa Timur</span>
      </span>
    </a>

    <!-- Menu desktop -->
    <ul class="hidden items-center gap-1 lg:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.url}
              class:list={[
                'rounded-full px-3.5 py-2 text-sm font-medium transition-colors',
                isActive(item.url)
                  ? 'bg-brand-50 text-brand-800'
                  : 'text-slate-600 hover:bg-slate-100 hover:text-brand-800',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <div class="hidden items-center gap-2 lg:flex">
      <a
        href={settings.admissionsUrl}
        class="rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-transform hover:-translate-y-0.5 hover:bg-brand-700"
      >
        {settings.admissionsLabel}
      </a>
    </div>

    <!-- Tombol menu mobile -->
    <button
      id="nav-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-xl p-2 text-brand-800 hover:bg-slate-100 lg:hidden"
      aria-label="Buka menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div id="mobile-nav" class="hidden border-t border-slate-200 bg-white lg:hidden">
    <ul class="space-y-1 px-4 py-4">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.url}
              class:list={[
                'block rounded-xl px-4 py-3 text-base font-medium',
                isActive(item.url) ? 'bg-brand-50 text-brand-800' : 'text-slate-700 hover:bg-slate-100',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href={settings.admissionsUrl} class="block rounded-xl bg-brand-600 px-4 py-3 text-center text-base font-semibold text-white">
          Info {settings.admissionsLabel}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
