---
import { getPage } from '../lib/content';
interface Props {
  settings: Record<string, any>;
}
const { settings } = Astro.props;
const footer = await getPage('footer');
const year = new Date().getFullYear();
---

<footer class="mt-20 bg-primary text-slate-400">
  <div class="container-x grid grid-cols-1 gap-10 py-16 md:grid-cols-12">
    <!-- About -->
    <div class="md:col-span-5">
      <div class="flex items-center gap-3">
        <img src={settings.logo} alt="Logo" width="40" height="40" class="h-10 w-10" />
        <span class="font-display text-lg font-bold text-white">{settings.schoolName}</span>
      </div>
      <p class="mt-5 max-w-md text-sm leading-relaxed">{footer.about}</p>
      <p class="mt-5 font-mono text-xs uppercase tracking-wider text-slate-500">NPSN {settings.npsn} · Akreditasi {settings.akreditasi}</p>
    </div>

    <!-- Quick links -->
    <div class="md:col-span-3">
      <h4 class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-white">Navigasi</h4>
      <ul class="mt-5 space-y-2.5 text-sm">
        {
          footer.quickLinks?.map((l: any) => (
            <li>
              <a href={l.url} class="transition-colors hover:text-accent-light">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Contact -->
    <div class="md:col-span-4">
      <h4 class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-white">Kontak</h4>
      <ul class="mt-5 space-y-3 text-sm">
        <li class="leading-relaxed">{settings.address}</li>
        <li>Telp: {settings.phone}</li>
        <li>
          Email: <a href={`mailto:${settings.email}`} class="hover:text-accent-light">{settings.email}</a>
        </li>
        <li>
          <a href={settings.mapsUrl} target="_blank" rel="noopener" class="text-accent-light underline underline-offset-2"
            >Lihat di Google Maps →</a
          >
        </li>
      </ul>
    </div>
  </div>

  <!-- KKN block -->
  <div class="border-t border-white/10">
    <div class="container-x grid grid-cols-1 gap-8 py-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <span class="eyebrow">{footer.kknTitle}</span>
        <p class="mt-4 max-w-md text-sm leading-relaxed">{footer.kknText}</p>
        <p class="mt-4 text-sm text-white">
          {footer.kknGroup} · {footer.kknInstitution} · {footer.kknYear}
        </p>
      </div>
      <div class="md:col-span-7">
        <h4 class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-white">Anggota Tim KKN</h4>
        <ul class="mt-5 grid grid-cols-1 gap-x-6 gap-y-2 text-sm sm:grid-cols-2">
          {
            footer.kknMembers?.map((m: string, i: number) => (
              <li class="flex items-baseline gap-3 border-b border-white/5 pb-2">
                <span class="font-mono text-xs text-accent-light">{String(i + 1).padStart(2, '0')}</span>
                <span>{m}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-6 text-xs text-slate-500 sm:flex-row">
      <p>© {year} {footer.copyright}</p>
      <p>{footer.credit}</p>
    </div>
  </div>
</footer>
