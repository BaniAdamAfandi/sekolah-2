---
import { formatDate } from '../lib/utils';
interface Props {
  href: string;
  title: string;
  category: string;
  date: Date | string;
  excerpt?: string;
}
const { href, title, category, date, excerpt } = Astro.props;
---

<a
  href={href}
  class="group block border-b border-line py-6 transition-transform duration-300 hover:translate-x-2"
>
  <div class="flex flex-wrap items-center gap-3">
    <span class="badge">{category}</span>
    <time class="font-mono text-xs uppercase tracking-wider text-ink/60">{formatDate(date)}</time>
  </div>
  <h3 class="mt-3 text-xl font-bold leading-snug text-primary transition-colors group-hover:text-accent md:text-2xl">
    {title}
  </h3>
  {excerpt && <p class="mt-2 max-w-2xl text-sm leading-relaxed text-ink">{excerpt}</p>}
</a>
