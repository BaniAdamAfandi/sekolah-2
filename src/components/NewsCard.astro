---
import { formatDate } from '../lib/utils';
interface Props {
  href: string;
  title: string;
  category: string;
  date: Date | string;
  excerpt?: string;
  thumbnail?: string;
}
const { href, title, category, date, excerpt, thumbnail } = Astro.props;

// Warna gradient fallback per kategori bila belum ada gambar sampul
const grad: Record<string, string> = {
  Akademik: 'from-brand-600 to-brand-800',
  Pengumuman: 'from-navy to-brand-700',
  Prestasi: 'from-amber to-brand-600',
  Ekstrakurikuler: 'from-brand-500 to-navy',
};
const g = grad[category] ?? 'from-brand-600 to-navy';
---

<a href={href} class="card group flex h-full flex-col overflow-hidden hover:-translate-y-1 hover:shadow-card-hover">
  <div class="relative aspect-[16/10] w-full overflow-hidden">
    {
      thumbnail ? (
        <img src={thumbnail} alt={title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
      ) : (
        <div class:list={['flex h-full w-full items-center justify-center bg-gradient-to-br', g]}>
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-opacity="0.6" stroke-width="1.5">
            <path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2" />
            <path d="M18 14h-8M15 18h-5M10 6h8v4h-8V6z" />
          </svg>
        </div>
      )
    }
    <span class="absolute left-3 top-3 badge bg-white/90 backdrop-blur">{category}</span>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <time class="text-xs font-semibold uppercase tracking-wide text-ink/50">{formatDate(date)}</time>
    <h3 class="mt-2 text-lg font-bold leading-snug text-navy transition-colors group-hover:text-brand-700">{title}</h3>
    {excerpt && <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-ink">{excerpt}</p>}
    <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700">
      Baca selengkapnya
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
  </div>
</a>
