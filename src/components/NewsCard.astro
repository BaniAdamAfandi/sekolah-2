---
import { formatDate } from '../lib/utils';
interface Props {
  href: string;
  title: string;
  category: string;
  date: Date | string;
  excerpt?: string;
  thumbnail?: string;
}
const { href, title, category, date, excerpt, thumbnail } = Astro.props;
---

<article class="card card-lift group flex flex-col overflow-hidden">
  <a href={href} class="block">
    <div class="relative aspect-video overflow-hidden bg-gradient-to-br from-brand-100 via-brand-50 to-accent/20">
      {
        thumbnail ? (
          <img src={thumbnail} alt={title} class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center text-brand-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" />
            </svg>
          </div>
        )
      }
      <span class="badge absolute left-3 top-3">{category}</span>
    </div>
  </a>
  <div class="flex flex-1 flex-col p-5">
    <time class="text-xs font-medium text-slate-400">{formatDate(date)}</time>
    <h3 class="mt-2 font-display text-lg font-bold leading-snug text-ink">
      <a href={href} class="transition-colors group-hover:text-brand-800">{title}</a>
    </h3>
    {excerpt && <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-slate-600">{excerpt}</p>}
    <a href={href} class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 transition-all group-hover:gap-2 group-hover:text-brand-800">
      Baca selengkapnya
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </a>
  </div>
</article>
